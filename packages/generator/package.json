{
  "name": "@rsp/generator",
  "version": "0.1.0",
  "type": "module",
  "description": "Generator for RSP setup configuration",
  "scripts": {
    "build": "pnpm run fetch-skills && pnpm run generate",
    "fetch-skills": "node --import tsx scripts/fetch-built-in-skills.ts",
    "generate": "node --import tsx src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0"
  }
}
