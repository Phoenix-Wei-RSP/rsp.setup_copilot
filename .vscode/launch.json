{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Generator (TSX)",
      "cwd": "${workspaceFolder}/packages/generator",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--import",
        "tsx"
      ],
      "args": [
        "${workspaceFolder}/packages/generator/src/generate.ts"
      ],
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/**"
      ]
    },
    {
      "type": "node-terminal",
      "name": "Run pnpm generate",
      "request": "launch",
      "command": "pnpm --filter @rsp/generator run generate",
      "cwd": "${workspaceFolder}"
    }
  ]
}
